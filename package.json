{
  "name": "control-asistencia",
  "version": "0.1.0",
  "private": true,
  "description": "Attendance Control MVP — PIN-based clock in/out with offline sync",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/infrastructure/db/seed.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "dexie": "^4.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.42.0",
    "jose": "^6.0.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.0",
    "lucide-react": "^0.485.0",
    "next": "^15.2.0",
    "postgres": "^3.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.0.0",
    "workbox-background-sync": "^7.3.0",
    "workbox-precaching": "^7.3.0",
    "workbox-routing": "^7.3.0",
    "workbox-strategies": "^7.3.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
