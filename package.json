    "@tailwindcss/typography": "^0.5.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/supertest": "^6.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "cypress": "^14.3.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.24.0",
    "eslint-config-next": "^15.2.0",
    "postcss": "^8.5.0",
    "prettier": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "supertest": "^7.1.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.22.4",
